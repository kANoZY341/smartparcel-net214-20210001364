from flask import Flask, jsonify, request, g
from datetime import datetime
from decimal import Decimal
import boto3
from boto3.dynamodb.conditions import Key
from botocore.exceptions import ClientError
import socket
import uuid
import os
import json

app = Flask(__name__)
app.config["MAX_CONTENT_LENGTH"] = 5 * 1024 * 1024  # 5 MB max upload

REGION = "ap-southeast-2"
TABLE_NAME = "smartparcel-parcels"
BUCKET_NAME = "smartparcel-photos-20210001364"
QUEUE_URL = "https://sqs.ap-southeast-2.amazonaws.com/362586210312/smartparcel-notifications-20210001364"

dynamodb = boto3.resource("dynamodb", region_name=REGION)
table = dynamodb.Table(TABLE_NAME)
s3 = boto3.client("s3", region_name=REGION)
sqs = boto3.client("sqs", region_name=REGION)

API_KEYS = {
    "key-admin-001": {"role": "admin", "name": "Admin"},
    "key-driver-001": {"role": "driver", "name": "Driver"},
    "key-customer-001": {"role": "customer", "name": "Customer"},
}

VALID_STATUSES = {"pending", "picked_up", "in_transit", "delivered", "cancelled"}
ALLOWED_EXTENSIONS = {".jpg", ".jpeg", ".png"}


def now_iso():
    return datetime.utcnow().isoformat() + "Z"


def error_response(message, status_code):
    return jsonify({"error": message}), status_code


def clean_decimals(obj):
    if isinstance(obj, list):
        return [clean_decimals(i) for i in obj]
    if isinstance(obj, dict):
        return {k: clean_decimals(v) for k, v in obj.items()}
    if isinstance(obj, Decimal):
        return int(obj) if obj % 1 == 0 else float(obj)
    return obj


@app.before_request
def log_request():
    print(f"[{now_iso()}] {request.method} {request.path}")


def require_auth(allowed_roles=None):
    def decorator(func):
        def wrapper(*args, **kwargs):
            api_key = request.headers.get("X-API-Key")
            if not api_key or api_key not in API_KEYS:
                return error_response("Unauthorized: missing or invalid API key", 401)

            user = API_KEYS[api_key]
            g.user = user

            if allowed_roles and user["role"] not in allowed_roles:
                return error_response("Forbidden: insufficient permissions", 403)

            return func(*args, **kwargs)

        wrapper.__name__ = func.__name__
        return wrapper
    return decorator


def contains_injection(value):
    bad_patterns = ["'", "DROP TABLE", "SELECT *", "--", ";"]
    text = str(value).upper()
    return any(p in text for p in bad_patterns)


def validate_text_field(name, value, max_len=200):
    if not value or not isinstance(value, str):
        return f"{name} is required and must be a string"
    if len(value.strip()) == 0:
        return f"{name} cannot be empty"
    if len(value) > max_len:
        return f"{name} exceeds maximum length of {max_len}"
    if contains_injection(value):
        return f"{name} contains invalid characters or patterns"
    return None


def allowed_file(filename):
    _, ext = os.path.splitext(filename.lower())
    return ext in ALLOWED_EXTENSIONS


@app.errorhandler(Exception)
def handle_exception(e):
    print(f"Unhandled exception: {str(e)}")
    return error_response("Internal server error", 500)


@app.route("/health", methods=["GET"])
def health():
    return jsonify({
        "status": "healthy",
        "hostname": socket.gethostname()
    }), 200


@app.route("/api/parcels", methods=["POST"])
@require_auth(allowed_roles=["admin", "driver"])
def create_parcel():
    if not request.is_json:
        return error_response("Request must be JSON", 400)

    data = request.get_json(silent=True)
    if not data:
        return error_response("Invalid or missing JSON body", 400)

    sender = data.get("sender")
    receiver = data.get("receiver")
    address = data.get("address")
    email = data.get("email")

    for field_name, field_value in [
        ("sender", sender),
        ("receiver", receiver),
        ("address", address),
        ("email", email),
    ]:
        err = validate_text_field(field_name, field_value)
        if err:
            return error_response(err, 400)

    parcel_id = "PKG-" + uuid.uuid4().hex[:8].upper()
    timestamp = now_iso()

    parcel = {
        "parcel_id": parcel_id,
        "sender": sender,
        "receiver": receiver,
        "address": address,
        "email": email,
        "status": "pending",
        "created_at": timestamp,
        "history": [
            {
                "status": "pending",
                "timestamp": timestamp,
                "updated_by": g.user["name"]
            }
        ]
    }

    table.put_item(Item=parcel)

    return jsonify({
        "message": "Parcel created successfully",
        "parcel_id": parcel_id,
        "parcel": parcel
    }), 201


@app.route("/api/parcels/<parcel_id>", methods=["GET"])
@require_auth(allowed_roles=["admin", "driver", "customer"])
def get_parcel(parcel_id):
    response = table.get_item(Key={"parcel_id": parcel_id})
    parcel = response.get("Item")

    if not parcel:
        return error_response("Parcel not found", 404)

    return jsonify(clean_decimals(parcel)), 200


@app.route("/api/parcels/<parcel_id>/status", methods=["PUT"])
@require_auth(allowed_roles=["driver"])
def update_status(parcel_id):
    response = table.get_item(Key={"parcel_id": parcel_id})
    parcel = response.get("Item")

    if not parcel:
        return error_response("Parcel not found", 404)

    if not request.is_json:
        return error_response("Request must be JSON", 400)

    data = request.get_json(silent=True)
    if not data:
        return error_response("Invalid or missing JSON body", 400)

    new_status = data.get("status")
    if new_status not in {"picked_up", "in_transit", "delivered"}:
        return error_response("Invalid status value", 400)

    if parcel["status"] == "cancelled":
        return error_response("Cannot update status of a cancelled parcel", 409)

    parcel["status"] = new_status
    parcel["history"].append({
        "status": new_status,
        "timestamp": now_iso(),
        "updated_by": g.user["name"]
    })

    table.put_item(Item=parcel)

    message = {
        "parcel_id": parcel_id,
        "new_status": new_status,
        "customer_email": parcel.get("email"),
        "driver_name": g.user["name"],
        "timestamp": now_iso(),
        "photo_url": parcel.get("photo_url", "")
    }

    sqs.send_message(
        QueueUrl=QUEUE_URL,
        MessageBody=json.dumps(message)
    )

    return jsonify({
        "message": "Parcel status updated successfully",
        "parcel_id": parcel_id,
        "new_status": new_status,
        "parcel": clean_decimals(parcel)
    }), 200


@app.route("/api/parcels", methods=["GET"])
@require_auth(allowed_roles=["admin"])
def list_parcels():
    status_filter = request.args.get("status")

    if status_filter:
        if status_filter not in VALID_STATUSES:
            return error_response("Invalid status filter", 400)

        response = table.query(
            IndexName="status-index",
            KeyConditionExpression=Key("status").eq(status_filter)
        )
        items = response.get("Items", [])
        return jsonify({"count": len(items), "parcels": clean_decimals(items)}), 200

    response = table.scan()
    items = response.get("Items", [])
    return jsonify({"count": len(items), "parcels": clean_decimals(items)}), 200


@app.route("/api/parcels/<parcel_id>", methods=["DELETE"])
@require_auth(allowed_roles=["admin"])
def cancel_parcel(parcel_id):
    response = table.get_item(Key={"parcel_id": parcel_id})
    parcel = response.get("Item")

    if not parcel:
        return error_response("Parcel not found", 404)

    if parcel["status"] in {"picked_up", "in_transit", "delivered"}:
        return error_response("Parcel cannot be cancelled after pickup", 409)

    parcel["status"] = "cancelled"
    parcel["history"].append({
        "status": "cancelled",
        "timestamp": now_iso(),
        "updated_by": g.user["name"]
    })

    table.put_item(Item=parcel)

    return jsonify({
        "message": "Parcel cancelled successfully",
        "parcel_id": parcel_id,
        "parcel": clean_decimals(parcel)
    }), 200


@app.route("/api/parcels/<parcel_id>/photo", methods=["POST"])
@require_auth(allowed_roles=["driver"])
def upload_photo(parcel_id):
    response = table.get_item(Key={"parcel_id": parcel_id})
    parcel = response.get("Item")

    if not parcel:
        return error_response("Parcel not found", 404)

    if "photo" not in request.files:
        return error_response("No photo file provided", 400)

    file = request.files["photo"]

    if file.filename == "":
        return error_response("Empty filename", 400)

    if not allowed_file(file.filename):
        return error_response("Only .jpg, .jpeg, .png files are allowed", 400)

    _, ext = os.path.splitext(file.filename.lower())
    s3_key = f"{parcel_id}/proof{ext}"

    try:
        s3.upload_fileobj(
            file,
            BUCKET_NAME,
            s3_key,
            ExtraArgs={
                "ContentType": file.content_type or "application/octet-stream",
                "ServerSideEncryption": "AES256"
            }
        )
    except ClientError as e:
        print(f"S3 upload error: {str(e)}")
        return error_response("Failed to upload photo to S3", 500)

    photo_url = f"s3://{BUCKET_NAME}/{s3_key}"
    parcel["photo_url"] = photo_url
    parcel["history"].append({
        "status": "photo_uploaded",
        "timestamp": now_iso(),
        "updated_by": g.user["name"]
    })

    table.put_item(Item=parcel)

    return jsonify({
        "message": "Photo uploaded successfully",
        "parcel_id": parcel_id,
        "photo_url": photo_url
    }), 200


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=8080, threaded=True)
